{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "../src/*"
      ],
      "@web/*": [
        "./*"
      ]
    }
  },
  "include": [
    "../src/**/*.ts",
    "./**/*.ts",
    "./**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "../src/app",
    "../src/components",
    "../src/stores",
    "../src/lib/push.ts",
    "../src/lib/supabase.ts",
    "../src/lib/api.ts"
  ]
}
