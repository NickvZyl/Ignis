{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "web",
    "scripts",
    "backup-src-*",
    ".expo",
    "dist",
    "src/lib/anthropic.ts",
    "src/lib/openrouter.ts",
    "src/lib/emotional-engine.ts",
    "src/lib/reflection-engine.ts",
    "src/lib/llm",
    "src/prompts"
  ]
}
